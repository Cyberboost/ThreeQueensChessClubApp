# ============================================================
# Three Queens Chess Club — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets.
# Production and preview variables are managed in Vercel Project Settings.
# ============================================================

# ─── Database (Neon Postgres) ───────────────────────────────
# Use the pooled connection URL for the app (Prisma Accelerate or direct)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Some providers (e.g. Neon) recommend a separate URL for migrations
# DATABASE_URL_UNPOOLED="postgresql://user:password@host/db?sslmode=require"

# ─── Clerk Authentication ───────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk redirect paths after sign-in/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ─── App Config ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Realtime (Ably) — Optional for MVP ─────────────────────
# ABLY_API_KEY="..."
# NEXT_PUBLIC_ABLY_CLIENT_ID="..."

# ─── Stockfish / AI Engine — Optional for MVP ───────────────
# STOCKFISH_API_URL="..."
# STOCKFISH_API_KEY="..."

# ─── Monitoring — Optional ──────────────────────────────────
# SENTRY_DSN="..."
# NEXT_PUBLIC_SENTRY_DSN="..."
